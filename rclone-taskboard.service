[Unit]
Description=Rclone taskboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/rclone-taskboard/taskboard/backend
EnvironmentFile=-/opt/rclone-taskboard/taskboard/.env
ExecStart=/opt/rclone-taskboard/taskboard/.venv/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
